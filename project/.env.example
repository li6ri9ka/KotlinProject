# App
PORT=8080

# PostgreSQL
DB_JDBC_URL=jdbc:postgresql://postgres:5432/shop_db
DB_USERNAME=shop
DB_PASSWORD=shop
DB_RUN_MIGRATIONS=true

# JWT
JWT_SECRET=change-me-in-production
JWT_ISSUER=shop-service
JWT_AUDIENCE=shop-clients
JWT_REALM=shop-api
JWT_EXPIRES_IN_SECONDS=3600

# Admin bootstrap (optional, but recommended for first start)
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=admin123

# Redis
REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PRODUCT_TTL_SECONDS=300
REDIS_ORDER_TTL_SECONDS=120

# RabbitMQ
RABBITMQ_ENABLED=true
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
